<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.store.vinyl.VinylBookController">
   <children>
      <Label layoutX="250.0" layoutY="20.0" text="Vinyl Details">
         <font><Font size="18.0" /></font>
      </Label>

      <Label layoutX="50.0" layoutY="80.0" text="Title:" />
      <Label fx:id="titleLabel" layoutX="200.0" layoutY="80.0" />

      <Label layoutX="50.0" layoutY="120.0" text="Artist:" />
      <Label fx:id="artistLabel" layoutX="200.0" layoutY="120.0" />

      <Label layoutX="50.0" layoutY="160.0" text="Release Year:" />
      <Label fx:id="releaseYearLabel" layoutX="200.0" layoutY="160.0" />

      <Label layoutX="50.0" layoutY="200.0" text="Borrowed By:" />
      <Label fx:id="borrowedByLabel" layoutX="200.0" layoutY="200.0" />

      <Label layoutX="50.0" layoutY="240.0" text="Reserved By:" />
      <Label fx:id="reservedByLabel" layoutX="200.0" layoutY="240.0" />

      <Label layoutX="50.0" layoutY="280.0" text="State:" />
      <Label fx:id="stateLabel" layoutX="200.0" layoutY="280.0" />

      <Label layoutX="50.0" layoutY="316.0" text="Name:" />
      <TextField fx:id="nameField" layoutX="200.0" layoutY="312.0" prefWidth="150.0" />

      <Label layoutX="50.0" layoutY="356.0" text="User ID:" />
      <TextField fx:id="userIdField" layoutX="200.0" layoutY="352.0" prefWidth="150.0" />

      <Button fx:id="borrowButton" layoutX="200.0" layoutY="390.0" text="Borrow" onAction="#handleBorrow"
              style="-fx-background-color: #51D03A; -fx-background-radius: 30;" textFill="WHITE" prefWidth="90.0" />
      <Button fx:id="returnButton" layoutX="310.0" layoutY="390.0" text="Return" onAction="#handleReturn"
              style="-fx-background-color: #D03A3A; -fx-background-radius: 30;" textFill="WHITE" prefWidth="90.0" />

      <Label fx:id="errorLabel" layoutX="200.0" layoutY="430.0" textFill="RED" />
   </children>
</AnchorPane>